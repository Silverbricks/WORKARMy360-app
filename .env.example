# ---------------------------------------------------------------------------
# WorkArmy 2.0 — environment template. Copy to .env and fill in.
# ---------------------------------------------------------------------------

# --- Database (Postgres / Neon) ---------------------------------------------
# Pooled connection for the app:
DATABASE_URL="postgresql://user:password@host/workarmy?sslmode=require"
# Unpooled/direct connection for Prisma migrations (Neon: the non-pooler host):
DIRECT_URL="postgresql://user:password@host/workarmy?sslmode=require"

# --- Auth -------------------------------------------------------------------
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
ACCESS_TOKEN_TTL=900            # seconds (15 min)
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_HASHER=bcrypt          # bcrypt | argon2

# --- Email (OTP + password reset) -------------------------------------------
EMAIL_PROVIDER=console          # console | resend
EMAIL_FROM="WorkArmy <no-reply@workarmy.co>"
RESEND_API_KEY=

# --- Cloudflare Turnstile (bot check) ---------------------------------------
TURNSTILE_ENABLED=false
TURNSTILE_SECRET=

# --- Backend server ---------------------------------------------------------
API_PORT=4000                   # local only; hosts (Railway/Cloud Run) inject PORT
API_GLOBAL_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000   # prod: your Vercel URL, e.g. https://workarmy360-users.vercel.app
COOKIE_DOMAIN=                  # leave empty (host-only). Set only for a shared parent domain.
COOKIE_SECURE=false             # true in production (https)
COOKIE_SAMESITE=lax             # prod cross-site (Vercel <-> Railway): set to "none" (needs COOKIE_SECURE=true)

# --- Frontend (Next.js public vars) -----------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_PROVIDERS_URL=http://localhost:3001
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
