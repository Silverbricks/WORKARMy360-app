// WorkArmy 2.0 — neutral core schema (Sprint 1).
// Principle 2: ONE persons, ONE organisations; participant type is an ATTRIBUTE.
// Principle 4: profile completeness (a flag on persons) is kept separate from
// compliance (credentials/verifications — added in a later sprint).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- enums -----------------------------------------------------------------

enum AccountType {
  JOB_SEEKER
  EMPLOYER
  FARM
  CONTRACTOR
  LABOUR_HIRE
  RECRUITMENT_AGENCY
}

enum AuthIdentityProvider {
  LOCAL
  GOOGLE // reserved; Sprint 1 ships LOCAL only
}

enum OtpPurpose {
  EMAIL_VERIFICATION // LOGIN_2FA etc. added later
}

enum OtpChannel {
  EMAIL // SMS added later
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AuditAction {
  USER_REGISTERED
  EMAIL_VERIFIED
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESHED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  ACCOUNT_LOCKED
  OTP_SENT
  OTP_FAILED
  ORG_CREATED
  JOB_PUBLISHED
  JOB_CLOSED
  APPLICATION_SUBMITTED
  APPLICATION_STAGE_CHANGED
  ORG_VERIFIED
  ORG_REJECTED
  DOCUMENT_UPLOADED
}

/// Platform staff role (admins are auth users with no provider org).
enum AdminRole {
  SUPER_ADMIN
  SUB_ADMIN
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStage {
  APPLIED
  SHORTLISTED
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentKind {
  LICENCE
  INSURANCE
  ID
  CERTIFICATE
  OTHER
}

enum ShiftStatus {
  OPEN
  FILLED
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  ASSIGNED
  CONFIRMED
  COMPLETED
  NO_SHOW
  SWAP_REQUESTED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum SwapStatus {
  OPEN
  ACCEPTED
  DECLINED
  CANCELLED
}

enum GroupKind {
  POOL
  TEAM
}

enum TicketStatus {
  OPEN
  RESOLVED
}

enum ServiceCategory {
  ACCOMMODATION
  TRANSPORT
}

enum ServiceKind {
  HAVE
  NEED
  SHARE
}

// --- WA ID -----------------------------------------------------------------

/// Single global, atomic counter. One monotonic WA###### sequence shared by
/// persons + organisations so every member id is globally unique and never
/// recycled. Incremented via INSERT ... ON CONFLICT DO UPDATE ... RETURNING.
model WaIdCounter {
  id        String   @id // always "GLOBAL"
  lastValue BigInt   @default(0) @map("last_value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("wa_id_counters")
}

// --- identity & auth (users = AUTH ONLY) -----------------------------------

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  email               String     @unique
  passwordHash        String?    @map("password_hash") // null until set (OAuth-ready)
  emailVerified       Boolean    @default(false) @map("email_verified")
  status              UserStatus @default(PENDING)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts") @db.SmallInt
  lockedUntil         DateTime?  @map("locked_until")
  lastLoginAt         DateTime?  @map("last_login_at")
  adminRole           AdminRole? @map("admin_role") // null for normal members
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  person         Person?
  identities     AuthIdentity[]
  sessions       Session[]
  otpCodes       OtpCode[]
  passwordResets PasswordReset[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  settings       UserSettings?

  @@map("users")
}

model AuthIdentity {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  provider       AuthIdentityProvider
  providerUserId String               @map("provider_user_id") // email for LOCAL, sub for GOOGLE
  createdAt      DateTime             @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

/// Refresh-token store. The raw token lives only in the httpOnly cookie; we keep
/// its sha256 hash. Rotated on every /auth/refresh.
model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// --- the person (human) — identity/profile lives here ----------------------

model Person {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @unique @map("user_id") @db.Uuid
  waId            String      @unique @map("wa_id") // immutable, e.g. WA100001
  accountType     AccountType @map("account_type") // attribute, not a table
  firstName       String?     @map("first_name")
  lastName        String?     @map("last_name")
  mobile          String? // AU normalised, e.g. 0412345678
  profileComplete Boolean     @default(false) @map("profile_complete") // != compliance
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile        PersonProfile?
  resume         Resume?
  experiences    WorkExperience[]
  orgMemberships OrgMember[]
  applications   JobApplication[]
  savedJobs      SavedJob[]
  documents      Document[]
  credentials    Credential[]
  verifications  Verification[]
  assignments      ShiftAssignment[]
  timesheets       Timesheet[]
  payslips         Payslip[]
  groupMemberships GroupMember[]
  feedback         Feedback[]
  supportTickets   SupportTicket[]
  conversations    Conversation[]
  serviceListings  ServiceListing[]
  workLogs         WorkLog[]

  @@map("persons")
}

/// Type-specific extension of a person (the Job Seeker profile). Completeness
/// lives HERE (a UX progress metric); compliance is separate (credentials +
/// verifications). Dates are stored as ISO "YYYY-MM-DD" strings for simple,
/// timezone-safe form round-trips (mirrors OrgProfile's all-string approach).
model PersonProfile {
  personId       String   @id @map("person_id") @db.Uuid
  // personal
  photoUrl        String?  @map("photo_url")
  photoDocumentId String?  @map("photo_document_id") // uploaded profile photo (Document id)
  dateOfBirth    String?  @map("date_of_birth")
  gender         String?
  nationality    String?
  addressLine    String?  @map("address_line")
  suburb         String?
  state          String?
  postcode       String?
  emergencyName  String?  @map("emergency_name")
  emergencyPhone String?  @map("emergency_phone")
  // professional
  headline       String? // professional summary / headline
  about          String?
  skills         String? // comma-separated for now
  industries     String?
  languages      String?
  // availability
  availability   String? // full-time / part-time / casual / seasonal / contract
  availableDays  String?  @map("available_days")
  availableHours String?  @map("available_hours")
  // hire-me status
  hireStatus     String?  @map("hire_status") // AVAILABLE_NOW / AVAILABLE_SOON / OPEN / NOT_LOOKING
  // job preferences (drive matching — NOT completeness, Principle 4)
  seekerCategory      String?  @map("seeker_category")
  userTypes           String?  @map("user_types") // csv: Permanent,Casual,Seasonal,...
  preferredLocations  String?  @map("preferred_locations") // csv, max 3
  preferredIndustries String?  @map("preferred_industries") // csv
  preferredJobTypes   String?  @map("preferred_job_types") // csv
  preferredPayMin     Int?     @map("preferred_pay_min")
  willingToRelocate   Boolean  @default(false) @map("willing_to_relocate")
  completeness   Int      @default(0)
  updatedAt      DateTime @updatedAt @map("updated_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("person_profiles")
}

/// A seeker's resume — headline/summary + cover letters + an uploaded file, with
/// a shareable public token. documentId references a Document (no FK — soft link).
model Resume {
  personId     String   @id @map("person_id") @db.Uuid
  documentId   String?  @map("document_id") @db.Uuid
  headline     String?
  summary      String?
  coverLetters Json?    @map("cover_letters") // [{ title, body }]
  shareToken   String   @unique @map("share_token")
  isPublic     Boolean  @default(false) @map("is_public")
  updatedAt    DateTime @updatedAt @map("updated_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

/// A job a seeker has saved/bookmarked (join row — like JobApplication, no WA ID).
model SavedJob {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([personId, jobId])
  @@index([personId])
  @@map("saved_jobs")
}

/// Repeatable employment-history entry for a person (mirrors Contact for orgs).
model WorkExperience {
  id             String   @id @default(uuid()) @db.Uuid
  personId       String   @map("person_id") @db.Uuid
  employer       String
  position       String?
  employmentType String?  @map("employment_type")
  location       String?
  startDate      String?  @map("start_date") // ISO YYYY-MM-DD
  endDate        String?  @map("end_date") // ISO YYYY-MM-DD
  current        Boolean  @default(false)
  summary        String?
  createdAt      DateTime @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("work_experiences")
}

// --- organisations (neutral stub for the provider flow, Sprint 2) ----------

model Organisation {
  id          String      @id @default(uuid()) @db.Uuid
  waId        String      @unique @map("wa_id")
  accountType AccountType @map("account_type") // EMPLOYER / FARM / CONTRACTOR / ...
  name        String
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  members       OrgMember[]
  profile       OrgProfile?
  contacts      Contact[]
  jobs          Job[]
  documents     Document[]
  credentials   Credential[]
  verifications Verification[]
  shifts        Shift[]
  timesheets    Timesheet[]
  payslips      Payslip[]
  conversations Conversation[]

  @@map("organisations")
}

/// Type-specific extension of an organisation. Completeness lives HERE (a UX
/// progress metric); compliance is separate (credentials + verifications).
model OrgProfile {
  orgId         String   @id @map("org_id") @db.Uuid
  legalName     String?  @map("legal_name")
  tradingName   String?  @map("trading_name")
  abn           String?
  structure     String? // Company / Sole Trader / Partnership / Trust
  industry      String?
  workforceSize String?  @map("workforce_size")
  about         String?
  website       String?
  addressLine   String?  @map("address_line")
  suburb        String?
  state         String?
  postcode      String?
  region        String?
  extension     Json? // farm crops / agency specialisations / etc.
  completeness  Int      @default(0)
  updatedAt     DateTime @updatedAt @map("updated_at")

  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_profiles")
}

/// Repeatable contact entity (Provider onboarding spec) — never flat columns.
/// Exactly one isPrimary per org (enforced in service + partial unique index).
model Contact {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  position    String?
  email       String?
  phone       String?
  roleTag     String?  @map("role_tag") // Accounts / Supervisor / Safety / HR / Operations
  isPrimary   Boolean  @default(false) @map("is_primary")
  isBilling   Boolean  @default(false) @map("is_billing")
  isEmergency Boolean  @default(false) @map("is_emergency")
  isSignatory Boolean  @default(false) @map("is_signatory")
  createdAt   DateTime @default(now()) @map("created_at")

  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("contacts")
}

// --- jobs & applications (the marketplace loop) ----------------------------

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  waId           String?   @unique @map("wa_id")
  title          String
  description    String?
  status         JobStatus @default(DRAFT)
  category       String?
  employmentType String?   @map("employment_type") // full-time / casual / seasonal / contract
  location       String?
  suburb         String?
  state          String?
  payMin         Int?      @map("pay_min")
  payMax         Int?      @map("pay_max")
  payUnit        String?   @map("pay_unit") // hour / day / week / year
  positions      Int       @default(1)
  startDate      DateTime? @map("start_date")
  publishedAt    DateTime? @map("published_at")
  closedAt       DateTime? @map("closed_at")
  extension      Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organisation Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applications JobApplication[]
  savedBy      SavedJob[]

  @@index([orgId])
  @@index([status, state])
  @@map("jobs")
}

model JobApplication {
  id        String           @id @default(uuid()) @db.Uuid
  jobId     String           @map("job_id") @db.Uuid
  personId  String           @map("person_id") @db.Uuid
  stage     ApplicationStage @default(APPLIED)
  coverNote String?          @map("cover_note")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  job    Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  person Person             @relation(fields: [personId], references: [id], onDelete: Cascade)
  events ApplicationEvent[]

  @@unique([jobId, personId])
  @@index([jobId, stage])
  @@index([personId])
  @@map("job_applications")
}

model ApplicationEvent {
  id            String            @id @default(uuid()) @db.Uuid
  applicationId String            @map("application_id") @db.Uuid
  fromStage     ApplicationStage? @map("from_stage")
  toStage       ApplicationStage  @map("to_stage")
  actorUserId   String?           @map("actor_user_id") @db.Uuid
  note          String?
  createdAt     DateTime          @default(now()) @map("created_at")

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_events")
}

// --- documents & compliance (separate from profile completeness) -----------

model Document {
  id               String       @id @default(uuid()) @db.Uuid
  ownerOrgId       String?      @map("owner_org_id") @db.Uuid
  ownerPersonId    String?      @map("owner_person_id") @db.Uuid
  kind             DocumentKind @default(OTHER)
  fileName         String       @map("file_name")
  storageKey       String       @map("storage_key")
  mimeType         String?      @map("mime_type")
  sizeBytes        Int?         @map("size_bytes")
  uploadedByUserId String       @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at")

  organisation Organisation? @relation(fields: [ownerOrgId], references: [id], onDelete: Cascade)
  person       Person?       @relation(fields: [ownerPersonId], references: [id], onDelete: Cascade)
  credentials  Credential[]

  @@index([ownerOrgId])
  @@index([ownerPersonId])
  @@map("documents")
}

model Credential {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String?   @map("org_id") @db.Uuid
  personId      String?   @map("person_id") @db.Uuid
  type          String // licence / insurance / abn / right-to-work / police-check
  identifier    String?
  issuer        String?
  expiresAt     DateTime? @map("expires_at")
  documentId    String?   @map("document_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")

  organisation Organisation?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  person       Person?        @relation(fields: [personId], references: [id], onDelete: Cascade)
  document     Document?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  verifications Verification[]

  @@index([orgId])
  @@index([personId])
  @@map("credentials")
}

model Verification {
  id               String             @id @default(uuid()) @db.Uuid
  subjectOrgId     String?            @map("subject_org_id") @db.Uuid
  subjectPersonId  String?            @map("subject_person_id") @db.Uuid
  credentialId     String?            @map("credential_id") @db.Uuid
  status           VerificationStatus @default(PENDING)
  reviewedByUserId String?            @map("reviewed_by_user_id") @db.Uuid
  reviewNote       String?            @map("review_note")
  reviewedAt       DateTime?          @map("reviewed_at")
  createdAt        DateTime           @default(now()) @map("created_at")

  organisation Organisation? @relation(fields: [subjectOrgId], references: [id], onDelete: Cascade)
  person       Person?       @relation(fields: [subjectPersonId], references: [id], onDelete: Cascade)
  credential   Credential?   @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("verifications")
}

model OrgMember {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  role      String   @default("owner") // neutral string; RBAC enum deferred
  createdAt DateTime @default(now()) @map("created_at")

  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([orgId, personId])
  @@map("org_members")
}

// --- work & earnings (two-sided: org creates shifts, person works them) -----

model Shift {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  jobId        String?     @map("job_id") @db.Uuid // soft link (no FK)
  title        String
  location     String?
  suburb       String?
  state        String?
  startAt      DateTime    @map("start_at")
  endAt        DateTime    @map("end_at")
  breakMinutes Int         @default(0) @map("break_minutes")
  payRate      Int?        @map("pay_rate") // dollars per unit
  payUnit      String?     @map("pay_unit") // hour / day / shift
  positions    Int         @default(1)
  notes        String?
  status       ShiftStatus @default(OPEN)
  createdAt    DateTime    @default(now()) @map("created_at")

  organisation Organisation      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignments  ShiftAssignment[]

  @@index([orgId])
  @@map("shifts")
}

model ShiftAssignment {
  id        String           @id @default(uuid()) @db.Uuid
  shiftId   String           @map("shift_id") @db.Uuid
  personId  String           @map("person_id") @db.Uuid
  status    AssignmentStatus @default(ASSIGNED)
  createdAt DateTime         @default(now()) @map("created_at")

  shift        Shift             @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  person       Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  attendance   Attendance?
  swapRequests ShiftSwapRequest[]

  @@unique([shiftId, personId])
  @@index([personId])
  @@map("shift_assignments")
}

model Attendance {
  id          String    @id @default(uuid()) @db.Uuid
  assignmentId String   @unique @map("assignment_id") @db.Uuid
  clockInAt   DateTime? @map("clock_in_at")
  clockOutAt  DateTime? @map("clock_out_at")
  clockInLat  Float?    @map("clock_in_lat")
  clockInLng  Float?    @map("clock_in_lng")
  clockOutLat Float?    @map("clock_out_lat")
  clockOutLng Float?    @map("clock_out_lng")

  assignment ShiftAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("attendance")
}

model Timesheet {
  id         String          @id @default(uuid()) @db.Uuid
  personId   String          @map("person_id") @db.Uuid
  orgId      String          @map("org_id") @db.Uuid
  weekStart  String          @map("week_start") // ISO YYYY-MM-DD (Monday)
  status     TimesheetStatus @default(DRAFT)
  totalHours Float           @default(0) @map("total_hours")
  createdAt  DateTime        @default(now()) @map("created_at")

  person       Person           @relation(fields: [personId], references: [id], onDelete: Cascade)
  organisation Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entries      TimesheetEntry[]

  @@index([personId])
  @@index([orgId, status])
  @@map("timesheets")
}

model TimesheetEntry {
  id          String  @id @default(uuid()) @db.Uuid
  timesheetId String  @map("timesheet_id") @db.Uuid
  shiftId     String? @map("shift_id") @db.Uuid
  date        String // ISO YYYY-MM-DD
  hours       Float
  note        String?

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@index([timesheetId])
  @@map("timesheet_entries")
}

model Payslip {
  id             String   @id @default(uuid()) @db.Uuid
  personId       String   @map("person_id") @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  periodStart    String   @map("period_start")
  periodEnd      String   @map("period_end")
  hours          Float    @default(0)
  grossPay       Int      @default(0) @map("gross_pay")
  tax            Int      @default(0)
  superannuation Int      @default(0)
  netPay         Int      @default(0) @map("net_pay")
  documentId     String?  @map("document_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([orgId])
  @@map("payslips")
}

model ShiftSwapRequest {
  id                  String     @id @default(uuid()) @db.Uuid
  assignmentId        String     @map("assignment_id") @db.Uuid
  requestedByPersonId String     @map("requested_by_person_id") @db.Uuid
  status              SwapStatus @default(OPEN)
  note                String?
  createdAt           DateTime   @default(now()) @map("created_at")

  assignment ShiftAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("shift_swap_requests")
}

// --- community (knowledge, groups/pools/teams, feedback) -------------------

model KnowledgeArticle {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  title     String
  category  String // Pay rates / Work rights / How-to / Skills / Stories
  body      String
  published Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("knowledge_articles")
}

model Group {
  id            String      @id @default(uuid()) @db.Uuid
  kind          GroupKind   @default(POOL)
  name          String
  description   String?
  ownerPersonId String      @map("owner_person_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")

  members GroupMember[]

  @@index([kind])
  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([groupId, personId])
  @@index([personId])
  @@map("group_members")
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  kind      String // idea / product / feature
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("feedback")
}

// --- support, messages, notifications, settings ----------------------------

model SupportTicket {
  id        String       @id @default(uuid()) @db.Uuid
  personId  String       @map("person_id") @db.Uuid
  category  String // Workplace / Payroll / Safety / Accommodation / Transport / Emergency / Other
  subject   String
  body      String
  status    TicketStatus @default(OPEN)
  response  String?
  createdAt DateTime     @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("support_tickets")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  kind      String // job / application / interview / compliance / payslip / message / system
  title     String
  body      String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model UserSettings {
  userId           String   @id @map("user_id") @db.Uuid
  notifyJobs       Boolean  @default(true) @map("notify_jobs")
  notifyMessages   Boolean  @default(true) @map("notify_messages")
  notifyCompliance Boolean  @default(true) @map("notify_compliance")
  profilePublic    Boolean  @default(false) @map("profile_public")
  language         String   @default("en-AU")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// 1:1 conversation between a person and an organisation (either side can post).
model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([personId, orgId])
  @@index([personId])
  @@index([orgId])
  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderUserId   String    @map("sender_user_id") @db.Uuid // no FK — soft link
  body           String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

/// A personal manual timesheet entry (hours against a free-text employer).
model WorkLog {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  employer  String
  date      String // ISO YYYY-MM-DD
  hours     Float
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("work_logs")
}

/// A worker-posted accommodation/transport listing (have / need / share).
model ServiceListing {
  id        String          @id @default(uuid()) @db.Uuid
  personId  String          @map("person_id") @db.Uuid
  category  ServiceCategory
  kind      ServiceKind
  title     String
  details   String?
  location  String?
  createdAt DateTime        @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([category])
  @@map("service_listings")
}

// --- OTP & password reset (hashed, attempt-capped) -------------------------

model OtpCode {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  purpose    OtpPurpose @default(EMAIL_VERIFICATION)
  channel    OtpChannel @default(EMAIL)
  codeHash   String     @map("code_hash") // sha256, never plaintext
  attempts   Int        @default(0)
  expiresAt  DateTime   @map("expires_at")
  consumedAt DateTime?  @map("consumed_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("otp_codes")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") // sha256, single-use
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// --- audit trail (compliance-grade, separate from profile) -----------------

model AuditLog {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String?     @map("user_id") @db.Uuid
  action    AuditAction
  ipAddress String?     @map("ip_address")
  userAgent String?     @map("user_agent")
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
