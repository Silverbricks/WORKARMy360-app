// --- work readiness (Gate 3) + tax -----------------------------------------

enum EngagementType {
  EMPLOYEE
  CONTRACT
}

enum TaxLodgementKind {
  PERSONAL
  ABN
}

enum TaxLodgementStatus {
  REQUESTED
  IN_PROGRESS
  COMPLETED
}

/// A seeker's work-readiness + tax details (Gate 3). Sensitive fields (TFN, bank)
/// are stored as-is for now — encryption-at-rest is a tracked follow-up.
model WorkReadiness {
  personId    String          @id @map("person_id") @db.Uuid
  engagement  EngagementType?
  tfn         String? // SENSITIVE
  abn         String? // 11 digits (contract path)
  hasSuper    Boolean         @default(false) @map("has_super")
  superFund   String?         @map("super_fund")
  superMember String?         @map("super_member")
  bankBsb     String?         @map("bank_bsb")
  bankAccount String?         @map("bank_account") // SENSITIVE
  noCashAck   Boolean         @default(false) @map("no_cash_ack")
  bankLater   Boolean         @default(false) @map("bank_later")
  workReady   Boolean         @default(false) @map("work_ready") // computed snapshot
  updatedAt   DateTime        @updatedAt @map("updated_at")

  person     Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  lodgements TaxLodgement[]
  shares     TaxShare[]

  @@map("work_readiness")
}

model TaxLodgement {
  id            String             @id @default(uuid()) @db.Uuid
  personId      String             @map("person_id") @db.Uuid
  kind          TaxLodgementKind
  financialYear String             @map("financial_year") // e.g. "2024-25"
  note          String?
  status        TaxLodgementStatus @default(REQUESTED)
  createdAt     DateTime           @default(now()) @map("created_at")

  readiness WorkReadiness @relation(fields: [personId], references: [personId], onDelete: Cascade)

  @@index([personId])
  @@map("tax_lodgements")
}

model TaxShare {
  id                String   @id @default(uuid()) @db.Uuid
  personId          String   @map("person_id") @db.Uuid
  employer          String
  passwordProtected Boolean  @default(false) @map("password_protected")
  sharedAt          DateTime @default(now()) @map("shared_at")

  readiness WorkReadiness @relation(fields: [personId], references: [personId], onDelete: Cascade)

  @@index([personId])
  @@map("tax_shares")
}

// --- invoices (contract billing) -------------------------------------------

enum InvoiceStatus {
  SENT
  PAID
}

enum InvoiceLineKind {
  HOURLY
  PIECE
}

/// A worker-issued invoice for contract work (gated on a valid ABN). Money is in
/// cents to support GST precision.
model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  personId      String        @map("person_id") @db.Uuid
  number        String
  clientName    String        @map("client_name")
  clientAbn     String?       @map("client_abn")
  date          String // ISO YYYY-MM-DD
  gst           Boolean       @default(false)
  notes         String?
  status        InvoiceStatus @default(SENT)
  subtotalCents Int           @default(0) @map("subtotal_cents")
  gstCents      Int           @default(0) @map("gst_cents")
  totalCents    Int           @default(0) @map("total_cents")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  person    Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]

  @@unique([personId, number])
  @@index([personId])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String          @id @default(uuid()) @db.Uuid
  invoiceId      String          @map("invoice_id") @db.Uuid
  kind           InvoiceLineKind
  description    String
  qty            Int             @default(1)
  rateCents      Int             @default(0) @map("rate_cents")
  lineTotalCents Int             @default(0) @map("line_total_cents")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// --- support, messages, notifications, settings ----------------------------

model SupportTicket {
  id        String       @id @default(uuid()) @db.Uuid
  personId  String       @map("person_id") @db.Uuid
  category  String // Workplace / Payroll / Safety / Accommodation / Transport / Emergency / Other
  subject   String
  body      String
  status    TicketStatus @default(OPEN)
  response  String?
  createdAt DateTime     @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("support_tickets")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  kind      String // job / application / interview / compliance / payslip / message / system
  title     String
  body      String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model UserSettings {
  userId           String   @id @map("user_id") @db.Uuid
  notifyJobs       Boolean  @default(true) @map("notify_jobs")
  notifyMessages   Boolean  @default(true) @map("notify_messages")
  notifyCompliance Boolean  @default(true) @map("notify_compliance")
  profilePublic    Boolean  @default(false) @map("profile_public")
  language         String   @default("en-AU")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// 1:1 conversation between a person and an organisation (either side can post).
model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([personId, orgId])
  @@index([personId])
  @@index([orgId])
  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderUserId   String    @map("sender_user_id") @db.Uuid // no FK — soft link
  body           String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

/// A personal manual timesheet entry (hours against a free-text employer).
model WorkLog {
  id        String   @id @default(uuid()) @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  employer  String
  date      String // ISO YYYY-MM-DD
  hours     Float
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("work_logs")
}

/// A worker-posted accommodation/transport listing (have / need / share).
model ServiceListing {
  id        String          @id @default(uuid()) @db.Uuid
  personId  String          @map("person_id") @db.Uuid
  category  ServiceCategory
  kind      ServiceKind
  title     String
  details   String?
  location  String?
  createdAt DateTime        @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([category])
  @@map("service_listings")
}

// --- OTP & password reset (hashed, attempt-capped) -------------------------

model OtpCode {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  purpose    OtpPurpose @default(EMAIL_VERIFICATION)
  channel    OtpChannel @default(EMAIL)
  codeHash   String     @map("code_hash") // sha256, never plaintext
  attempts   Int        @default(0)
  expiresAt  DateTime   @map("expires_at")
  consumedAt DateTime?  @map("consumed_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("otp_codes")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") // sha256, single-use
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// --- audit trail (compliance-grade, separate from profile) -----------------

model AuditLog {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String?     @map("user_id") @db.Uuid
  action    AuditAction
  ipAddress String?     @map("ip_address")
  userAgent String?     @map("user_agent")
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ===========================================================================
//  BUSINESS DASHBOARD — Staff (org workers, teams)
// ===========================================================================

/// A worker linked to an org's roster (on-call / urgent flags). Distinct from
/// per-shift ShiftAssignment — this is the standing relationship.
model OrgWorker {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  personId         String   @map("person_id") @db.Uuid
  staffType        String?  @map("staff_type")
  onCall           Boolean  @default(false) @map("on_call")
  urgentAvailable  Boolean  @default(false) @map("urgent_available")
  availabilityNote String?  @map("availability_note")
  teamId           String?  @map("team_id") @db.Uuid
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([orgId, personId])
  @@index([orgId])
  @@map("org_workers")
}

model Team {
  id                 String   @id @default(uuid()) @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  name               String
  description        String?
  supervisorMemberId String?  @map("supervisor_member_id") @db.Uuid // soft link to OrgMember
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members      TeamMember[]

  @@index([orgId])
  @@map("teams")
}

model TeamMember {
  id         String   @id @default(uuid()) @db.Uuid
  teamId     String   @map("team_id") @db.Uuid
  personId   String   @map("person_id") @db.Uuid
  roleInTeam String?  @map("role_in_team")
  createdAt  DateTime @default(now()) @map("created_at")

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([teamId, personId])
  @@map("team_members")
}

// ===========================================================================
//  BUSINESS DASHBOARD — Urgent & Bulk (staff requests, quick dispatch)
// ===========================================================================

enum StaffRequestType {
  URGENT_SHIFT
  BULK_CREW
  STANDARD
}

enum StaffRequestUrgency {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum StaffRequestStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  FILLED
  CLOSED
  CANCELLED
}

enum RecipientChannel {
  SUPER_ADMIN
  CONTRACTOR
  AGENCY
  NETWORK
}

enum RecipientStatus {
  SENT
  VIEWED
  ACCEPTED
  DECLINED
}

enum DispatchChannel {
  ON_CALL
  CONTRACTORS
  AGENCIES
  NETWORK
}

enum DispatchStatus {
  OPEN
  FILLED
  CLOSED
}

enum DispatchTargetState {
  SENT
  RESPONDED
  ACCEPTED
  DECLINED
}

/// A structured bulk/urgent staff request sent to WorkArmy Super Admin and
/// optionally selected contractors/agencies.
model StaffRequest {
  id              String              @id @default(uuid()) @db.Uuid
  orgId           String              @map("org_id") @db.Uuid
  type            StaffRequestType    @default(BULK_CREW)
  urgency         StaffRequestUrgency @default(NORMAL)
  status          StaffRequestStatus  @default(SENT)
  roleTitle       String              @map("role_title")
  industry        String?
  description     String?
  employmentType  String?             @map("employment_type")
  site            String?
  siteAddress     String?             @map("site_address")
  suburb          String?
  state           String?
  startDate       String?             @map("start_date") // ISO date
  shiftType       String?             @map("shift_type")
  startTime       String?             @map("start_time")
  finishTime      String?             @map("finish_time")
  headcountTotal  Int                 @default(1) @map("headcount_total")
  headcountMale   Int?                @map("headcount_male")
  headcountFemale Int?                @map("headcount_female")
  headcountAny    Int?                @map("headcount_any")
  days            String? // csv
  skills          String? // csv
  licences        String? // csv
  experience      String?
  english         String?
  ppe             String? // csv
  ppeSupplied     Boolean             @default(false) @map("ppe_supplied")
  reportToName    String?             @map("report_to_name")
  reportToRole    String?             @map("report_to_role")
  reportToMobile  String?             @map("report_to_mobile")
  reportToLocation String?            @map("report_to_location")
  siteNotes       String?             @map("site_notes")
  payRate         String?             @map("pay_rate")
  payBasis        String?             @map("pay_basis")
  award           String?
  transport       Boolean             @default(false)
  accommodation   Boolean             @default(false)
  meals           Boolean             @default(false)
  additionalNotes String?             @map("additional_notes")
  sendToSuperAdmin Boolean            @default(true) @map("send_to_super_admin")
  declarationAcceptedAt DateTime?     @map("declaration_accepted_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  organisation Organisation            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recipients   StaffRequestRecipient[]

  @@index([orgId])
  @@map("staff_requests")
}

model StaffRequestRecipient {
  id             String           @id @default(uuid()) @db.Uuid
  staffRequestId String           @map("staff_request_id") @db.Uuid
  channel        RecipientChannel
  recipientOrgId String?          @map("recipient_org_id") @db.Uuid // soft link
  recipientLabel String?          @map("recipient_label")
  status         RecipientStatus  @default(SENT)
  respondedAt    DateTime?        @map("responded_at")

  staffRequest StaffRequest @relation(fields: [staffRequestId], references: [id], onDelete: Cascade)

  @@index([staffRequestId])
  @@map("staff_request_recipients")
}

model Dispatch {
  id         String         @id @default(uuid()) @db.Uuid
  orgId      String         @map("org_id") @db.Uuid
  message    String
  roleNeeded String?        @map("role_needed")
  headcount  Int?
  whenAt     String?        @map("when_at")
  status     DispatchStatus @default(OPEN)
  createdAt  DateTime       @default(now()) @map("created_at")

  organisation Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  targets      DispatchTarget[]

  @@index([orgId])
  @@map("dispatches")
}

model DispatchTarget {
  id          String              @id @default(uuid()) @db.Uuid
  dispatchId  String              @map("dispatch_id") @db.Uuid
  channel     DispatchChannel
  targetLabel String?             @map("target_label")
  state       DispatchTargetState @default(SENT)
  respondedAt DateTime?           @map("responded_at")

  dispatch Dispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)

  @@index([dispatchId])
  @@map("dispatch_targets")
}

