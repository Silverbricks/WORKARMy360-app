{
  "name": "workarmy",
  "version": "2.0.0",
  "private": true,
  "description": "WorkArmy 2.0 — Australian workforce platform (clean rebuild)",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @workarmy/database db:generate",
    "db:migrate": "pnpm --filter @workarmy/database db:migrate",
    "db:seed": "pnpm --filter @workarmy/database db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
